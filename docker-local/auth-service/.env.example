# === OIDC / SSO ===
# Your OIDC discovery URL (Keycloak, Okta, Auth0, etc.)
OIDC_ISSUER_URL=https://sso.company.com/realms/your-realm
OIDC_AUDIENCE=your-client-id

# === NATS ===
# Account private seed (starts with SA) — used by auth-service to sign user JWTs
NATS_ACCOUNT_SEED=SAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Account public key (starts with A) — used in NATS resolver_preloads
NATS_ACCOUNT_PUBLIC_KEY=AXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Account JWT — full eyJ... string from `nsc describe account --raw`
NATS_ACCOUNT_JWT=eyJ0eXAiOiJKV1Qi...

# Operator JWT — full eyJ... string from `nsc describe operator --raw`
NATS_OPERATOR_JWT=eyJ0eXAiOiJKV1Qi...

# === Auth Service ===
PORT=8080
NATS_JWT_EXPIRY=1h
